package code;

public class SecondLargestNumber {

	public static void main(String[] args) {
		
		int a[] = {34, 9, 1, 6, 10};
		
		for(int i=0; i<a.length-1; i++)
		{
			int temp;
			for(int j=i+1; j<a.length; j++)
			{
				if(a[i] > a[j])
				{
					temp = a[i];
					a[i] = a[j];
					a[j] = temp;
					
				}
			}
		}

		System.out.println("Second Largest Number"+a[1]);
	}

}
